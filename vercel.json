{
  "rewrites": [
    {
      "source": "/store/:path*",
      "destination": "https://tangsong-production.up.railway.app/store/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://tangsong-production.up.railway.app/admin/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://tangsong-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://tangsong-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}